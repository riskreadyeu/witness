{
  "name": "witness",
  "version": "0.1.0-dev",
  "description": "A read-only AI pair programmer. No hands, by design.",
  "type": "module",
  "bin": {
    "witness": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "witness": "tsx src/index.ts",
    "eval": "tsx evals/runner.ts --pool public",
    "eval:all": "tsx evals/runner.ts --pool all",
    "eval:private": "tsx evals/runner.ts --pool private",
    "extract-fixtures": "tsx evals/extract-riskreadyeu.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.1.77",
    "zod": "^3.25.0",
    "zod-to-json-schema": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.5.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.0.0"
}
